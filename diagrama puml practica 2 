@startuml

class Personaje{
+vida
+mover()
+recibirDañio()
}

class Link{
+atacar()
+defender()
+usarObjeto()
}

class Zelda{
+usarMagia()
}

class Ganon{
+ataqueOscuro()
}

class Enemigo{
+atacar()
+perseguir()
}


class jefe{
+ataqueEspecial()
}

class Espada{
+dañio
+atacar()
}

class Escudo{
+defender()
}

class Arco{
+disparar()
}

class Flecha{
+danio
}

class Bomba{
+explotar()
}

class Corazon{
+curar()
}

class Rupia{
+valor
}

class Llave{
+abrir()
}

class Cofre{
+abrir()
}

class Mazmorra{
+entrar()
+completar()
+salir()
}

class Hechizo{
+lanzar()
}

class Inventario{
+agregarObjeto()
+usarObjeto()
}

class Mapa{
+mostrar()
}

class Trifuerza{
+otorgarPoder()
}

Link --> Personaje
Zelda --> Personaje
Ganon --> Personaje
Enemigo --> Personaje

jefe --> Enemigo

Link *-- Espada
Link *-- Escudo
Link *-- Inventario
Link *-- Corazon

Link *-- Rupia
Link o-- Arco
Link o-- Flecha
Link o-- Bomba
Link o-- Llave
Link o-- Mapa
Link o-- Hechizo

Zelda *-- Trifuerza

Ganon *-- Trifuerza
Ganon *-- Hechizo

Mazmorra *-- Cofre
Mazmorra *-- Enemigo
Mazmorra *-- jefe
Mazmorra *-- Llave

Cofre *-- Rupia
Cofre o-- Hechizo

@enduml